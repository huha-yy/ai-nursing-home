# ============================================================
# AI 养老院院长 MVP — 环境变量模板
# 复制为 infra/.env 并填入实际值
# ============================================================

# Postgres
POSTGRES_USER=dato
POSTGRES_PASSWORD=change_me
POSTGRES_DB=dato

# Caddy
CADDY_HTTPS_PORT=9443
CADDY_DOMAIN=localhost
# CADDY_ACME_EMAIL=admin@example.com

# Redis
REDIS_PORT=6379

# Timezone
TIMEZONE=Asia/Shanghai

# Docker socket proxy
DOCKER_PROXY_PORT=2375

# dl-control — 生成方式:
#   DL_CONTROL_SECRET_KEY=$(openssl rand -base64 24)
#   DL_CONTROL_APP_PASSWORD=$(openssl rand -hex 16)
SESSION_TTL_SECONDS=86400
LOGIN_RATE_LIMIT_FAILS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
DATO_DATA_ROOT=~/.local/share/dato
DL_CONTROL_SECRET_KEY=generate_a_random_secret_key_here
DL_CONTROL_APP_PASSWORD=generate_a_random_password_here

# LLM — 本地模型 (Ollama)
DL_LLM_LOCAL_MODEL=qwen3.5:9b
DL_LLM_LOCAL_KEEP_ALIVE=1800
DL_LLM_LOCAL_MEM=12g
DL_LLM_LOCAL_CPUS=4
DL_LLM_PROXY_RPM=30
COMPOSE_PROFILES=local-llm

# DeepSeek API (可选 — 本地模型不可用时的 fallback)
# DEEPSEEK_API_KEY=sk-your-key-here

# dl-cognee + 内部服务认证 — 生成方式:
#   DL_COGNEE_ADMIN_TOKEN=$(openssl rand -hex 32)
#   DL_INTERNAL_API_KEY=$(openssl rand -hex 32)
DL_COGNEE_ADMIN_TOKEN=generate_a_random_token_here
DL_INTERNAL_API_KEY=generate_a_random_key_here

# GBrain
# DL_GBRAIN_PG_PASSWORD=$(openssl rand -hex 16)
DL_GBRAIN_PG_PASSWORD=generate_a_random_password_here
