# Postgres
POSTGRES_USER=dato
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=dato

# Caddy
CADDY_HTTPS_PORT=9443
CADDY_DOMAIN=localhost
# CADDY_ACME_EMAIL=admin@example.com  # required for Let's Encrypt in prod

# Redis
REDIS_PORT=6379

# Timezone
TIMEZONE=Asia/Shanghai

# Docker socket proxy (unused until P2, pre-declared for future plans)
DOCKER_PROXY_PORT=2375

# dl-control (the admin service)
#
# The DB DSNs (DL_CONTROL_DB_URL, DL_CONTROL_MIGRATION_DB_URL) and
# DL_CONTROL_SITE_HOST are derived from POSTGRES_*/CADDY_DOMAIN by the
# compose environment — set the POSTGRES_* vars and CADDY_DOMAIN instead
# of editing the DSNs directly.
#
# DL_CONTROL_BOOTSTRAP_PASSWORD is optional; if unset, a random 24-char
# password is generated by `make control-bootstrap` and printed once.
#
# DL_CONTROL_SECRET_KEY and DL_CONTROL_APP_PASSWORD are generated into
# .env by `make up` if absent — never commit real values. To set them
# manually:
#   DL_CONTROL_SECRET_KEY=$(openssl rand -base64 24)
#   DL_CONTROL_APP_PASSWORD=$(openssl rand -hex 16)
SESSION_TTL_SECONDS=86400
LOGIN_RATE_LIMIT_FAILS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# P2 provisioning — MUST be an absolute path. dl-control sends it to the
# Docker daemon as a bind source and the daemon does NOT resolve it relative
# to the compose file.
DATO_DATA_ROOT=~/.local/share/dato

# P2: OpenClaw image tag for provisioned agent containers.
# DATO_OPENCLAW_IMAGE=dato-openclaw:2026.4.8

# P2: DeepSeek API key for model access (required).
# DEEPSEEK_API_KEY=sk-your-key-here

# P4: Local LLM endpoint for Tier 1 agents (required for Tier 1 provisioning).
# LOCAL_LLM_BASE_URL=https://your-llm-server/v1
# LOCAL_LLM_API_KEY=  (optional, if upstream requires auth)

# P4: DNS denylist extras (comma-separated hostnames to additionally block).
# DL_EGRESS_DNS_EXTRA_DENY=
# DL_EGRESS_DNS_DISABLE=0  (set to 1 for dev — disables the DNS guardrail)

# P5: Knowledge service
# DL_COGNEE_ADMIN_TOKEN is generated by make up if absent.
# DL_INTERNAL_API_KEY is the shared secret for internal service-to-service auth.
# DL_COGNEE_ADMIN_TOKEN=$(openssl rand -hex 32)
# DL_INTERNAL_API_KEY=$(openssl rand -hex 32)

# P10 — ComfyUI remote image generation (remote GPU node URL)
# Leave unset on servers without NVIDIA GPU — pipeline falls back to Pexels.
# COMFYUI_URL=http://192.168.10.70:8188

# P7 — dl-ota-watcher
DL_OTA_WATCHER_APP_PASSWORD=dev_password_change_me

# P6 — dl-llm-local
DL_LLM_LOCAL_MODEL=qwen3.5:9b
DL_LLM_LOCAL_KEEP_ALIVE=1800
DL_LLM_LOCAL_MEM=12g
DL_LLM_LOCAL_CPUS=4
DL_LLM_PROXY_RPM=30

# Activate the local-llm compose profile by default; set to empty string
# (or omit local-llm) if you don't want to run the in-appliance Ollama.
COMPOSE_PROFILES=local-llm

# --- P13c workflow SMTP (optional) ---------------------------------------
# Required only when a workflow that sends email (e.g. hr.onboarding_email)
# is enabled. Leave unset to keep email-sending flows unconfigured — their
# sends fail clean and retry, surfacing "SMTP is not configured" in the run.
# DL_CONTROL_SMTP_HOST=smtp.example.com
# DL_CONTROL_SMTP_PORT=587
# DL_CONTROL_SMTP_FROM=dato@example.com
# DL_CONTROL_SMTP_USERNAME=
# DL_CONTROL_SMTP_PASSWORD=
# DL_CONTROL_SMTP_STARTTLS=true

# GBrain — 一线知识平台
# DL_GBRAIN_PG_PASSWORD=$(openssl rand -hex 16)
# DL_GBRAIN_AUTH_USER=frontline
# DL_GBRAIN_AUTH_PASS_HASH=  # bcrypt hash from `caddy hash-password`
