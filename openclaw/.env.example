# ============================================================
# Content Pipeline — Environment Variables
# ============================================================
# Copy this file and fill in your values.
# The agent entrypoint loads /app/config/.env automatically.
# These vars are also needed in the agent's config .env.
# ============================================================

# -------- Feishu (required) --------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
# FEISHU_NOTIFY_OPEN_ID=

# -------- DeepSeek (required) --------
DEEPSEEK_API_KEY=

# -------- Pexels (required for image search) --------
PEXELS_API_KEY=

# -------- MiMo Omni (optional, for image analysis) --------
# XIAOMI_MIMO_API_KEY=

# -------- ComfyUI (optional, skip AI image gen if not set) --------
# COMFYUI_URL=http://127.0.0.1:8188
